# ─── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/safehail

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_min_64_chars
JWT_REFRESH_SECRET=change_me_to_a_different_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Firebase (FCM push notifications) ───────────────────
# Paste the entire service account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ─── Africa's Talking (SMS OTP) ──────────────────────────
AFRICAS_TALKING_API_KEY=your_api_key
AFRICAS_TALKING_USERNAME=sandbox
AFRICAS_TALKING_SENDER_ID=SafeHail

# ─── RevenueCat ──────────────────────────────────────────
REVENUECAT_WEBHOOK_SECRET=your_revenuecat_webhook_shared_secret

# ─── AWS S3 (avatar / document storage) ─────────────────
AWS_S3_BUCKET=safehail-media
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=af-south-1

# ─── CORS ────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://safehail.co.za

# ─── Rate limiting ───────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_GENERAL=60
RATE_LIMIT_MAX_AUTH=10
RATE_LIMIT_MAX_EMERGENCY=10
